# Agent Control Plane environment defaults
# Copy to .env and adjust for your machine/runtime.

ACP_APP_ENV=development
ACP_APP_NAME=Agent Control Plane
ACP_API_HOST=127.0.0.1
ACP_API_PORT=8000
ACP_WEB_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
ACP_RUNTIME_HOME=.acp
ACP_DATABASE_NAME=acp.sqlite3
ACP_BOOTSTRAP_AGENT_SKILL_PATH=skills/agent-control-plane-api/SKILL.md
ACP_BOOTSTRAP_AGENT_NAME=codex
ACP_BOOTSTRAP_AGENT_MODEL=
ACP_BOOTSTRAP_AGENT_PERMISSIONS=danger-full-access
ACP_BOOTSTRAP_AGENT_OUTPUT=
# Deprecated compatibility bridge (temporary): prefer adapter fields above.
ACP_BOOTSTRAP_AGENT_COMMAND_TEMPLATE=export ACP_RUNTIME_HOME={acp_runtime_home}; codex --dangerously-bypass-approvals-and-sandbox exec - < {prompt_file}
